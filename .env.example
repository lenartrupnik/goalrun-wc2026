# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use either name — both work (anon / publishable key from Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# World Cup API (optional override)
WORLDCUP_API_URL=https://worldcup26.ir

# Site URL for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: secret for external cron services (cron-job.org, etc.)
# Not needed on Vercel Hobby — the app uses client polling + rate limiting instead
CRON_SECRET=