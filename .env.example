# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# World Cup API (optional override)
WORLDCUP_API_URL=https://worldcup26.ir

# Site URL for OAuth redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret for Vercel scheduled sync (required in production)
CRON_SECRET=generate-a-random-secret-string